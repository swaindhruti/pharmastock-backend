# Application
APP_PORT=8080
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pharmastock-db
DB_SSL_MODE=disable

# File uploads
UPLOAD_DIR=./uploads

# JWT
JWT_SECRET=change-me-in-production

# Admin seed user (created on startup if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@pharmastock.com
