{{template "layout" .}}
{{define "content"}}
<h1>Inventory Lookup</h1>
<div class="card">
  <form hx-get="/inventory" hx-target="#results" hx-swap="innerHTML">
    <label for="medicine_id">Medicine ID</label>
    <input id="medicine_id" name="medicine_id" type="number" value="{{.medicineID}}" placeholder="Enter medicine ID" autofocus>
    <button type="submit" class="btn btn-primary mt-2">Search</button>
  </form>
</div>

<div id="results">{{template "inventory_results" .}}</div>
{{end}}