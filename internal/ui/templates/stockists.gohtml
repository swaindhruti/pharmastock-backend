{{template "layout" .}}
{{define "content"}}
<div class="flex-between mb-2">
  <h1>Stockists</h1>
  <button class="btn btn-primary" hx-get="/stockists/create" hx-target="#form-area" hx-swap="innerHTML">+ New</button>
</div>

{{if .error}}<div class="alert alert-error">{{.error}}</div>{{end}}

<div id="form-area" class="mb-2"></div>

<div id="stockist-list">{{template "stockists_list" .}}</div>
{{end}}